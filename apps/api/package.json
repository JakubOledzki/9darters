    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@9darters/shared": "file:../../packages/shared",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@node-rs/argon2": "^2.0.2",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.0.1",
    "mysql2": "^3.14.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
